docker rm -f qr-generator
docker build -t qr-generator-web .
mkdir -p /mnt/storage/media
docker run -d \
  --name qr-generator \
  -p 9191:9191 \
  --restart unless-stopped \
  -v /mnt/storage/media:/mnt/storage/media \
  -e MEDIA_STORAGE_DIR=/mnt/storage/media \
  -e MEDIA_PUBLIC_BASE_URL=https://media.fonon.uz \
  -e MAX_UPLOAD_SIZE_MB=5 \
  qr-generator-web
